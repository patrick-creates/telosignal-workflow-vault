# Required — all four must be set (no defaults in code)
API_ANTHROPIC_KEY=sk-or-...   # OpenRouter key (openrouter.ai/keys)

# Model — OpenRouter uses namespaced IDs (provider/model)
# API_MODEL=anthropic/claude-opus-4          # most capable, highest cost
# API_MODEL=anthropic/claude-sonnet-4-5      # balanced — recommended
# API_MODEL=anthropic/claude-haiku-3-5       # fastest, lowest cost
# API_MODEL=openai/gpt-4o                    # OpenAI via OpenRouter
API_MODEL=anthropic/claude-sonnet-4-5

WORKFLOW_GITHUB_RAW_BASE=https://raw.githubusercontent.com/YOUR_ORG/YOUR_REPO/main/workflows
WORKFLOW_EXTENSION=.md
