# API_MODEL=claude-sonnet-4-6        # balanced — recommended for most use cases
# API_MODEL=claude-haiku-4-5-20251001  # fastest, lowest cost
API_MODEL=claude-opus-4-7

WORKFLOW_GITHUB_RAW_BASE=https://raw.githubusercontent.com/YOUR_ORG/YOUR_REPO/main/workflows
WORKFLOW_EXTENSION=.md
